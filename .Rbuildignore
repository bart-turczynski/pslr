# R build/dev artifacts
^LICENSE\.md$
^.*\.Rproj$
^\.Rproj\.user$
^\.Rhistory$
^\.RData$
^\.Ruserdata$
^.*\.Rcheck$
^.*\.tar\.gz$
^\.lintr$
^cran-comments\.md$
^CRAN-SUBMISSION$
^doc$
^Meta$
# Shared scaffold layer: everything below is dev tooling, not package content,
# and would otherwise trip "non-standard files/directories" in R CMD check.
^\.github$
^\.editorconfig$
^\.env$
^\.env\.example$
^\.gitattributes$
^\.gitignore$
^\.pre-commit-config\.yaml$
^\.fp$
^FP_CLAUDE\.md$
^FP_AGENTS\.md$
^_scratch$
^bench$
^data-raw$
^docs$
^_pkgdown\.yml$
^CLAUDE\.md$
^AGENTS\.md$
^CONTRIBUTING\.md$
^SECURITY\.md$
^CHANGELOG\.md$
^CITATION\.cff$
^codemeta\.json$
^README\.Rmd$
^README\.html$
^\.DS_Store$
^ACKNOWLEDGMENTS\.md$
